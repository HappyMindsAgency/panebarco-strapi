{
  "collectionName": "components_shared_card_links",
  "info": {
    "displayName": "cardLink",
    "icon": "apps"
  },
  "options": {},
  "attributes": {
    "titolo": {
      "type": "string"
    },
    "contenuto": {
      "type": "richtext"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "url": {
      "type": "string"
    },
    "tag": {
      "type": "boolean",
      "default": false
    },
    "tags": {
      "type": "string",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "tag"
            },
            true
          ]
        }
      }
    }
  },
  "config": {}
}
